# chiavi private / certificati — MAI su GitHub (il repo e' pubblico).
# Aggiunti nel collaudo 2026-07-15: '.env*' era coperto, ma una chiave SSH o un certificato
# finito per sbaglio nella cartella sarebbe stato committato in SILENZIO da un `git add -A`.
# Verificato prima: nessun file gia' tracciato corrisponde a questi pattern.
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.pem
*.key
*.p12
*.pfx
*.ppk
*.jks
*.keystore
# copie offsite cifrate (mai nel repo)
bookinvip-offsite/
.offsite.env
.watchdog.env

# Uscite dei collaudi (si rigenerano a ogni esecuzione): il codice si
# versiona, i suoi rapporti no.
collaudi/rapporto_*.txt
collaudi/*.tsr
collaudi/*.tsq
collaudi/__pycache__/
collaudi/screenshot_visivi/

# Artefatti dei collaudi locali (coverage, Hypothesis, cache dei linter): si
# rigenerano ad ogni esecuzione -> MAI nel repo (altrimenti finiscono in un `git add -A`).
.coverage
.coverage.*
htmlcov/
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/


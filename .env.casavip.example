# Casa VIP - configurazione (copia in .env.casavip, NON committare i segreti).
# Genera il segreto:  python -c "import secrets; print(secrets.token_hex(32))"

# Segreto per firmare i prezzi/quote (HMAC). OBBLIGATORIO, >=32 byte hex.
CASAVIP_SEGRETO=cambiami_64_caratteri_hex

# Chiave per il pannello host (header X-Host-Key). Lascia vuoto = aperto (solo dev).
HOST_KEY=cambiami_chiave_host

# Valuta (solo etichetta; la matematica resta in centesimi interi)
VALUTA=EUR

# Sentinel FIM (difesa cartella) - opzionale
SENTINEL=false
SENTINEL_DIR=/app

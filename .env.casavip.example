# Casa VIP - configurazione (copia in .env.casavip, NON committare i segreti).
# Genera il segreto:  python -c "import secrets; print(secrets.token_hex(32))"

# Segreto per firmare i prezzi/quote (HMAC). OBBLIGATORIO, >=32 byte hex.
CASAVIP_SEGRETO=cambiami_64_caratteri_hex

# Chiave per il pannello host (header X-Host-Key). Lascia vuoto = aperto (solo dev).
HOST_KEY=cambiami_chiave_host

# Chiave per il pannello admin/rimborsi (header X-Admin-Key). Vuoto = aperto (solo dev).
ADMIN_KEY=cambiami_chiave_admin

# Valuta (solo etichetta; la matematica resta in centesimi interi)
VALUTA=EUR

# Dominio pubblico (per SEO: sitemap, canonical, JSON-LD). Senza https finale slash.
BASE_URL=https://bookinvip.com

# Store DENARO su file (in Docker: /data = volume persistente). Senza queste, il
# fallback "data/..." finisce DENTRO il container: niente crash (la cartella viene
# creata) ma i conti vanno PERSI a ogni rebuild (lezione deploy 2026-07-17).
DB_SPLIT=/data/split.db
DB_CODA=/data/coda.db

# Stripe (GATED): senza chiave la prenotazione conferma ma NON incassa. Appena metti la
# chiave, ogni prenotazione produce un link di pagamento reale (nessuna modifica codice).
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=https://bookinvip.com/grazie
STRIPE_CANCEL_URL=https://bookinvip.com/annullato
# Firma webhook (Dashboard Stripe > Developers > Webhooks > endpoint /api/payments/webhook)
STRIPE_WEBHOOK_SECRET=

# Email del voucher (GATED): senza SMTP_HOST nessuna email. Con la config, ogni
# prenotazione manda il voucher all'ospite (nessuna modifica codice).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_MITTENTE=info@bookinvip.com

# Commissione del CORE in basis-point (1500 = 15%). Auto -5% sui colossi.
COMMISSIONE_BPS=1500

# --- CANALI SOCIAL (GATED): i segreti vivono SOLO qui, MAI nel codice/Git ---
# Telegram (GRATIS): crea un bot con @BotFather, prendi il token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Facebook/Instagram (Pagina "BookinVip"). META_PAGE_TOKEN = token long-lived della Pagina
# (NON quello breve di Graph Explorer). META_IG_USER_ID = id IG Business collegato alla Pagina.
META_PAGE_ID=
META_PAGE_TOKEN=
META_IG_USER_ID=

# X / Twitter (ATTENZIONE: l'API di scrittura è A PAGAMENTO). OAuth 1.0a, 4 chiavi.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# TikTok (video-first): serve l'app approvata (Content Posting API) + un video URL.
TIKTOK_ACCESS_TOKEN=

# --- AUTO-PUBBLICAZIONE CAMPAGNA (GATED, default-off) ---
# Vuoto = niente auto-pubblicazione (usi il bottone "Pubblica campagna" nell'admin a mano).
# Metti un numero di giorni (es. 1 = ogni giorno, 7 = settimanale): il server pubblica la
# campagna da solo a quella cadenza, senza burst, ricordando l'ultima volta (stato durevole).
CAMPAGNA_AUTO_GIORNI=
CAMPAGNA_STATO_FILE=.campagna_stato.json

# Outreach B2B (fase89/95): file DUREVOLE delle disiscrizioni (opt-out). Il link "/stop"
# nelle email scrive qui; un opt-out va onorato per SEMPRE (obbligo legale).
OUTREACH_OPTOUT_FILE=.outreach_optout.json

# Sentinel FIM (difesa cartella) - opzionale
SENTINEL=false
SENTINEL_DIR=/app

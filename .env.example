# CORE_AUTO - Esempio di configurazione per il deploy (docker compose).
# Copia in `.env` e PERSONALIZZA. Il file `.env` NON va committato (gitignored).
#
# Genera i segreti con:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ─── Segreti applicazione (OBBLIGATORI in produzione: l'app fa fail-fast) ───
# Devono essere identici tra tutti i worker. CAMBIALI: non usare i default dev.
HMAC_SECRET=cambiami_hmac_64hex
API_KEY=cambiami_api_key
BEARER_TOKEN=cambiami_bearer_token
ADMIN_TOKEN=cambiami_admin_token        # richiesto per release/refund fondi

# ─── PostgreSQL (servizio interno; nessuna porta esposta sull'host) ───
POSTGRES_USER=core
POSTGRES_PASSWORD=cambiami_password_db
POSTGRES_DB=core_auto

# ─── Reverse proxy (unico punto esposto) ───
HTTP_PORT=80                            # in produzione con SSL: 443 (vedi DEPLOY.md)

# ─── App / runtime ───
FLASK_ENV=production
AUDIT_ENABLED=true

# ─── Opzionali / tuning (hanno default sensati nel codice) ───────────────
# DB_PATH=/data/marketplace.db          # core su SQLite (volume); impostato dal compose
# DB_BACKEND=sqlite                     # cutover a 'postgres' dopo il porting core (1.3c)
# GATEWAY_CLIENTS=chiave1:cliente1,chiave2:cliente2   # auth per-cliente del gateway
# TIMESTAMP_WINDOW=60
# MAX_BODY_BYTES=1048576
# OUTBOX_CONCURRENCY=4
# OUTBOX_DLQ_ALERT_THRESHOLD=10
# IDEMPOTENCY_TTL_HOURS=24
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# WEBHOOK_URL=

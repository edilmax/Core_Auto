# CORE_AUTO - Esempio di configurazione per il deploy (docker compose).
# Copia in `.env` e PERSONALIZZA. Il file `.env` NON va committato (gitignored).
#
# Genera i segreti con:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ─── Segreti applicazione (OBBLIGATORI in produzione: l'app fa fail-fast) ───
# Devono essere identici tra tutti i worker. CAMBIALI: non usare i default dev.
HMAC_SECRET=cambiami_hmac_64hex
API_KEY=cambiami_api_key
BEARER_TOKEN=cambiami_bearer_token
ADMIN_TOKEN=cambiami_admin_token        # richiesto per release/refund fondi

# ─── PostgreSQL (servizio interno; nessuna porta esposta sull'host) ───
POSTGRES_USER=core
POSTGRES_PASSWORD=cambiami_password_db
POSTGRES_DB=core_auto

# ─── Reverse proxy (unico punto esposto) ───
HTTP_PORT=80                            # in produzione con SSL: 443 (vedi DEPLOY.md)

# ─── App / runtime ───
FLASK_ENV=production
AUDIT_ENABLED=true

# ─── Stripe / Tavola VIP (pagamenti reali del modulo prenotazioni) ───
# Chiave segreta Stripe (test: sk_test_..., live: sk_live_...). NON committarla.
STRIPE_API_KEY=sk_test_inserisci_qui
# Firma webhook: Dashboard Stripe -> Developers -> Webhooks -> endpoint /api/v1/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_inserisci_qui
# API-key per le route /reservations (header X-Booking-Key) usata da agente/PR:
BOOKING_API_KEY=cambiami_booking_api_key
# Chiave ADMIN (header X-Admin-Key): autorizza APPROVA/RIFIUTA rimborsi (muove denaro):
BOOKING_ADMIN_KEY=cambiami_booking_admin_key
BOOKING_SUCCESS_URL=https://tavolavip.example/pagamento/ok
BOOKING_CANCEL_URL=https://tavolavip.example/pagamento/annullato
# Backup automatico DB (snapshot consistente + retention size-cap):
BACKUP_DIR=/data/backup
BACKUP_MAX_BYTES=524288000              # tetto TOTALE dei backup (500 MB) -> no disco pieno

# ─── Agente IA reale (Anthropic) per la chat di prenotazione ───
ANTHROPIC_API_KEY=sk-ant-inserisci_qui      # SOLO qui (gitignored), mai nel codice
ANTHROPIC_MODEL=claude-opus-4-8             # override opzionale del modello

# ─── WhatsApp Business API (invio automatico dei link di pagamento Stripe) ───
# VIA SCELTA: Meta WhatsApp Cloud API DIRETTA (REST via 'requests', gia' nei
# requirements; nessun markup BSP, stesso pattern del TelegramAdapter).
WHATSAPP_ENABLED=false                    # feature-flag: spento = comportamento attuale
WHATSAPP_ACCESS_TOKEN=inserisci_qui       # token system-user PERMANENTE (Bearer)
WHATSAPP_PHONE_NUMBER_ID=inserisci_qui    # id del numero mittente (NON il numero)
WHATSAPP_BUSINESS_ACCOUNT_ID=inserisci_qui   # WABA id (gestione template)
WHATSAPP_API_VERSION=v21.0
# Invio PROATTIVO (fuori dalla finestra 24h) -> richiede un TEMPLATE APPROVATO con
# bottone/variabile URL che ospita il link Stripe:
WHATSAPP_TEMPLATE_NAME=link_pagamento
WHATSAPP_TEMPLATE_LANG=it
# Webhook in ingresso (stato consegna / risposte cliente):
WHATSAPP_VERIFY_TOKEN=cambiami_verify_token   # handshake GET di verifica endpoint
WHATSAPP_APP_SECRET=inserisci_qui             # verifica firma X-Hub-Signature-256
#
# --- Alternativa: WhatsApp via Twilio (BSP fast-start) — usa UNA SOLA via ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # numero/sandbox Twilio (richiede 'twilio')

# ─── Opzionali / tuning (hanno default sensati nel codice) ───────────────
# DB_PATH=/data/marketplace.db          # core su SQLite (volume); impostato dal compose
# DB_BACKEND=sqlite                     # cutover a 'postgres' dopo il porting core (1.3c)
# GATEWAY_CLIENTS=chiave1:cliente1,chiave2:cliente2   # auth per-cliente del gateway
# TIMESTAMP_WINDOW=60
# MAX_BODY_BYTES=1048576
# OUTBOX_CONCURRENCY=4
# OUTBOX_DLQ_ALERT_THRESHOLD=10
# IDEMPOTENCY_TTL_HOURS=24
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# WEBHOOK_URL=
